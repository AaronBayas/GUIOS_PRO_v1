// prisma/schema.prisma
// Motor: SQLite (desarrollo) | ORM: Prisma | Stack: TypeScript

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────
// ENUMS (SQLite no soporta enums nativos, se usan Strings)
// ──────────────────────────────────────────────────────────────

// TipoImpacto: "Interno" | "Externo" | "Ambos"
// EvaluacionEstado: "Borrador" | "En_progreso" | "Completada" | "Archivada"
// Recomendacion: "A" | "B" | "C"
// ClasificacionFoda: "Fortaleza" | "Oportunidad" | "Debilidad" | "Amenaza"
// NivelImportancia: "Irrelevante" | "Opcional" | "Importante" | "Fundamental"
// AIEstado: "pendiente" | "procesando" | "completado" | "error"
// TipoSoftware: "ERP" | "CMS" | "CRM" | "IDE" | "SGBD" | "Ofimatica" | "Seguridad" | "Infraestructura" | "Comunicaciones" | "Analitica" | "Otro"

model Rol {
  rol_id   Int       @id @default(autoincrement())
  rol_name String    @unique
  usuarios Usuario[]

  @@map("rol")
}

model Usuario {
  usuario_id    Int      @id @default(autoincrement())
  rol_id        Int
  usuario_name  String
  email         String   @unique
  password_hash String
  activo        Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  rol              Rol                     @relation(fields: [rol_id], references: [rol_id])
  evaluaciones     Evaluacion[]
  colaboraciones   EvaluacionColaborador[]
  factor_versiones FactorVersion[]

  @@map("usuario")
}

model Dimension {
  dimension_id   Int      @id @default(autoincrement())
  dimension_name String   @unique
  orden          Int      @default(0)
  factores       Factor[]

  @@map("dimension")
}

model Factor {
  factor_id            Int      @id @default(autoincrement())
  dimension_id         Int
  factor_name          String
  tipo_impacto         String   @default("Externo")
  importancia_sugerida Int
  descripcion          String?
  activo               Boolean  @default(true)
  version_actual       Int      @default(1)
  orden                Int      @default(0)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  dimension         Dimension          @relation(fields: [dimension_id], references: [dimension_id])
  subfactores       Subfactor[]
  evaluacion_factor EvaluacionFactor[]
  versiones         FactorVersion[]

  @@map("factor")
}

model Subfactor {
  subfactor_id   Int      @id @default(autoincrement())
  factor_id      Int
  subfactor_name String
  es_critico     Boolean  @default(false)
  descripcion    String?
  orden          Int      @default(0)
  activo         Boolean  @default(true)
  created_at     DateTime @default(now())

  factor                 Factor                @relation(fields: [factor_id], references: [factor_id])
  evaluacion_subfactores EvaluacionSubfactor[]

  @@map("subfactor")
}

model Evaluacion {
  evaluacion_id Int @id @default(autoincrement())
  usuario_id    Int

  software_nombre      String
  software_version     String?
  software_tipo        String  @default("Otro")
  software_sitio_web   String?
  software_licencia    String?
  software_descripcion String?
  organizacion_nombre  String?
  organizacion_sector  String?
  evaluador_nombre     String?
  contexto_evaluacion  String?

  estado        String  @default("Borrador")
  paso_actual   Int     @default(1)
  recomendacion String?
  risk_score    Float?

  fecha_creacion  DateTime  @default(now())
  fecha_limite    DateTime?
  ultimo_guardado DateTime  @default(now())
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  usuario             Usuario                 @relation(fields: [usuario_id], references: [usuario_id])
  evaluacion_factores EvaluacionFactor[]
  colaboradores       EvaluacionColaborador[]
  ai_recomendacion    AIRecomendacion?
  historial_cambios   HistorialCambio[]

  @@map("evaluacion")
}

model EvaluacionFactor {
  efactor_id    Int @id @default(autoincrement())
  evaluacion_id Int
  factor_id     Int

  importancia_decisor  Int?
  importancia_relativa String?
  ponderacion_media    Float?
  clasificacion_foda   String?
  foda_interno         String?
  foda_externo         String?
  alcance_override     String?
  completado           Boolean  @default(false)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  evaluacion             Evaluacion            @relation(fields: [evaluacion_id], references: [evaluacion_id], onDelete: Cascade)
  factor                 Factor                @relation(fields: [factor_id], references: [factor_id])
  evaluacion_subfactores EvaluacionSubfactor[]

  @@unique([evaluacion_id, factor_id])
  @@map("evaluacion_factor")
}

model EvaluacionSubfactor {
  esubfactor_id Int      @id @default(autoincrement())
  efactor_id    Int
  subfactor_id  Int
  peso          Int?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  evaluacion_factor EvaluacionFactor @relation(fields: [efactor_id], references: [efactor_id], onDelete: Cascade)
  subfactor         Subfactor        @relation(fields: [subfactor_id], references: [subfactor_id])

  @@unique([efactor_id, subfactor_id])
  @@map("evaluacion_subfactor")
}

model EvaluacionColaborador {
  colaborador_id   Int       @id @default(autoincrement())
  evaluacion_id    Int
  usuario_id       Int
  aceptado         Boolean   @default(false)
  fecha_invitacion DateTime  @default(now())
  fecha_aceptacion DateTime?

  evaluacion Evaluacion @relation(fields: [evaluacion_id], references: [evaluacion_id], onDelete: Cascade)
  usuario    Usuario    @relation(fields: [usuario_id], references: [usuario_id])

  @@unique([evaluacion_id, usuario_id])
  @@map("evaluacion_colaborador")
}

model FactorVersion {
  version_id     Int      @id @default(autoincrement())
  factor_id      Int
  numero_version Int
  snapshot_json  String // JSON serializado
  motivo_cambio  String?
  creado_por     Int
  created_at     DateTime @default(now())

  factor  Factor  @relation(fields: [factor_id], references: [factor_id])
  usuario Usuario @relation(fields: [creado_por], references: [usuario_id])

  @@unique([factor_id, numero_version])
  @@map("factor_version")
}

model AIRecomendacion {
  ai_rec_id       Int      @id @default(autoincrement())
  evaluacion_id   Int      @unique
  modelo_usado    String
  prompt_usado    String?
  respuesta_texto String
  tokens_usados   Int?
  estado          String   @default("completado")
  created_at      DateTime @default(now())

  evaluacion Evaluacion @relation(fields: [evaluacion_id], references: [evaluacion_id], onDelete: Cascade)

  @@map("ai_recomendacion")
}

model HistorialCambio {
  historial_id  Int      @id @default(autoincrement())
  evaluacion_id Int
  tipo_cambio   String
  descripcion   String?
  snapshot_json String? // JSON serializado
  created_at    DateTime @default(now())

  evaluacion Evaluacion @relation(fields: [evaluacion_id], references: [evaluacion_id], onDelete: Cascade)

  @@map("historial_cambio")
}
